{
  "name": "my-skills",
  "version": "1.0.0",
  "type": "module",
  "description": "Self-hosted skills registry. Kilo/OpenCode plugin distributed as a tarball via Cloudflare Pages. Private source, public install.",
  "main": "./src/plugin.ts",
  "exports": {
    ".": "./src/plugin.ts"
  },
  "opencode": {
    "plugin": "./src/plugin.ts"
  },
  "kilocode": {
    "plugin": "./src/plugin.ts"
  },
  "files": [
    "src",
    "skills_list.json",
    "README.md"
  ],
  "scripts": {
    "build": "npm run clean && npm run pack",
    "pack": "mkdir -p dist && npm pack --pack-destination dist",
    "clean": "rm -rf dist",
    "dev": "bun run src/plugin.ts"
  },
  "dependencies": {
    "@kilocode/plugin": "latest"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.5.0"
  },
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=22.0.0"
  },
  "license": "MIT"
}
